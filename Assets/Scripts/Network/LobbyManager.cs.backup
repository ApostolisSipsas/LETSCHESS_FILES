using System.Collections.Generic;

public struct HostEntry
{
    public string name;
    public ushort port;

    public HostEntry(string name, ushort port)
    {
        this.name = name;
        this.port = port;
    }
}

public static class LobbyManager
{
    private static List<HostEntry> hosts = new List<HostEntry>();

    public static void RegisterHost(string name, ushort port)
    {
        UnregisterHost(port);
        hosts.Add(new HostEntry(name, port));
    }

    public static void UnregisterHost(ushort port)
    {
        hosts.RemoveAll(h => h.port == port);
    }

    public static List<HostEntry> GetHosts()
    {
        return new List<HostEntry>(hosts);
    }
}
